# このファイルは .env.local のテンプレートです（Gitに含めてOK）
# 実際の値は .env.local にコピーして記入し、絶対にコミットしないこと

# ===== Phase 2 以降：Supabase =====
# Supabase プロジェクトの URL と anon key
# 取得元: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxx...

# ===== Phase 3 以降：OpenAI =====
# OpenAI API キー（Vercel Serverless Functions でのみ使用）
# 注意: VITE_ プレフィックスを絶対につけないこと（フロントに露出する）
# 取得元: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx...
